#: gdk-pixbuf/gdk-pixbuf-animation.c:184 gdk-pixbuf/gdk-pixbuf-io.c:1216
#: gdk-pixbuf/gdk-pixbuf-io.c:1489
#, c-format
msgid "Failed to open file “%s”: %s"
msgstr "ບໍ່ສາມາດເປີດໄຟລ໌ “%s”: %s"

#: gdk-pixbuf/gdk-pixbuf-animation.c:197 gdk-pixbuf/gdk-pixbuf-io.c:1077
#, c-format
msgid "Image file “%s” contains no data"
msgstr "ໄຟລ໌ຮູບພາບ “%s” ບໍ່ມີຂໍ້ມູນ"

#: gdk-pixbuf/gdk-pixbuf-animation.c:235
#, c-format
msgid ""
"Failed to load animation “%s”: reason not known, probably a corrupt "
"animation file"
msgstr "ບໍ່ສາມາດໂຫຼດພາບເຄື່ອນໄຫວ “%s”: ບໍ່ຊາບສາເຫດ, ອາດເປັນຍ້ອນໄຟລ໌ພາບເຄື່ອນໄຫວເສຍຫາຍ"

#: gdk-pixbuf/gdk-pixbuf-animation.c:303 gdk-pixbuf/gdk-pixbuf-io.c:1252
#: gdk-pixbuf/gdk-pixbuf-io.c:1541
#, c-format
msgid ""
"Failed to load image “%s”: reason not known, probably a corrupt image file"
msgstr "ບໍ່ສາມາດໂຫຼດຮູບພາບ “%s”: ບໍ່ຊາບສາເຫດ, ອາດເປັນຍ້ອນໄຟລ໌ຮູບພາບເສຍຫາຍ"

#: gdk-pixbuf/gdk-pixbuf.c:248
msgid "Number of Channels"
msgstr "ຈຳນວນຊ່ອງສີ"

#: gdk-pixbuf/gdk-pixbuf.c:249
msgid "The number of samples per pixel"
msgstr "ຈຳນວນຕົວຢ່າງຕໍ່ພິກເຊວ"

#: gdk-pixbuf/gdk-pixbuf.c:264
msgid "Colorspace"
msgstr "ພື້ນທີ່ສີ"

#: gdk-pixbuf/gdk-pixbuf.c:265
msgid "The colorspace in which the samples are interpreted"
msgstr "ພື້ນທີ່ສີທີ່ໃຊ້ໃນການຕີຄວາມໝາຍຕົວຢ່າງ"

#: gdk-pixbuf/gdk-pixbuf.c:277
msgid "Has Alpha"
msgstr "ມີຊ່ອງອານຟາ"

#: gdk-pixbuf/gdk-pixbuf.c:278
msgid "Whether the pixbuf has an alpha channel"
msgstr "ກວດສອບວ່າ pixbuf ມີຊ່ອງອານຟາຫຼືບໍ່"

#: gdk-pixbuf/gdk-pixbuf.c:291
msgid "Bits per Sample"
msgstr "ບິດຕໍ່ຕົວຢ່າງ"

#: gdk-pixbuf/gdk-pixbuf.c:292
msgid "The number of bits per sample"
msgstr "ຈຳນວນບິດຕໍ່ຕົວຢ່າງ"

#: gdk-pixbuf/gdk-pixbuf.c:305
msgid "Width"
msgstr "ຄວາມກວ້າງ"

#: gdk-pixbuf/gdk-pixbuf.c:306
msgid "The number of columns of the pixbuf"
msgstr "ຈຳນວນຖັນ (ຄໍລຳ) ຂອງ pixbuf"

#: gdk-pixbuf/gdk-pixbuf.c:319
msgid "Height"
msgstr "ຄວາມສູງ"

#: gdk-pixbuf/gdk-pixbuf.c:320
msgid "The number of rows of the pixbuf"
msgstr "ຈຳນວນແຖວຂອງ pixbuf"

#: gdk-pixbuf/gdk-pixbuf.c:337
msgid "Rowstride"
msgstr "ໄລຍະຫ່າງແຖວ"

#: gdk-pixbuf/gdk-pixbuf.c:338
msgid ""
"The number of bytes between the start of a row and the start of the next row"
msgstr "ຈຳນວນໄບຕ໌ລະຫວ່າງຈຸດເລີ່ມຕົ້ນຂອງແຖວໜຶ່ງຫາຈຸດເລີ່ມຕົ້ນຂອງແຖວຖັດໄປ"

#: gdk-pixbuf/gdk-pixbuf.c:351
msgid "Pixels"
msgstr "ພິກເຊວ"

#: gdk-pixbuf/gdk-pixbuf.c:352
msgid "A pointer to the pixel data of the pixbuf"
msgstr "ຕົວຊີ້ໄປຫາຂໍ້ມູນພິກເຊວຂອງ pixbuf"

#: gdk-pixbuf/gdk-pixbuf.c:366
msgid "Pixel Bytes"
msgstr "ໄບຕ໌ພິກເຊວ"

#: gdk-pixbuf/gdk-pixbuf.c:367
msgid "Readonly pixel data"
msgstr "ຂໍ້ມູນພິກເຊວທີ່ອ່ານໄດ້ຢ່າງດຽວ"

#: gdk-pixbuf/gdk-pixbuf-io.c:893
#, c-format
msgid "Unable to load image-loading module: %s: %s"
msgstr "ບໍ່ສາມາດໂຫຼດໂມດູນສຳລັບໂຫຼດຮູບພາບ: %s: %s"

#: gdk-pixbuf/gdk-pixbuf-io.c:911
#, c-format
msgid ""
"Image-loading module %s does not export the proper interface; perhaps it’s "
"from a different gdk-pixbuf version?"
msgstr "ໂມດູນສຳລັບໂຫຼດຮູບພາບ %s ບໍ່ໄດ້ສົ່ງອອກສ່ວນຕິດຕໍ່ທີ່ຖືກຕ້ອງ; ອາດຈະມາຈາກ gdk-pixbuf ຄົນລະລຸ້ນ?"

#: gdk-pixbuf/gdk-pixbuf-io.c:921 gdk-pixbuf/gdk-pixbuf-io.c:964
#, c-format
msgid "Image type “%s” is not supported"
msgstr "ບໍ່ຮອງຮັບປະເພດຮູບພາບ “%s”"

#: gdk-pixbuf/gdk-pixbuf-io.c:1049
#, c-format
msgid "Couldn’t recognize the image file format for file “%s”"
msgstr "ບໍ່ສາມາດຮັບຮູ້ຮູບແບບໄຟລ໌ຮູບພາບສຳລັບໄຟລ໌ “%s”"

#: gdk-pixbuf/gdk-pixbuf-io.c:1057
msgid "Unrecognized image file format"
msgstr "ຮູບແບບໄຟລ໌ຮູບພາບທີ່ບໍ່ສາມາດຮັບຮູ້ໄດ້"

#: gdk-pixbuf/gdk-pixbuf-io.c:1263
#, c-format
msgid "Failed to load image “%s”: %s"
msgstr "ບໍ່ສາມາດໂຫຼດຮູບພາບ “%s”: %s"

#: gdk-pixbuf/gdk-pixbuf-io.c:2338 gdk-pixbuf/io-gdip-utils.c:840
#, c-format
msgid "Error writing to image file: %s"
msgstr "ຂຽນຂໍ້ມູນລົງໄຟລ໌ຮູບພາບຜິດພາດ: %s"

#: gdk-pixbuf/gdk-pixbuf-io.c:2380 gdk-pixbuf/gdk-pixbuf-io.c:2501
#, c-format
msgid "This build of gdk-pixbuf does not support saving the image format: %s"
msgstr "ລຸ້ນນີ້ gdk-pixbuf ບໍ່ຮອງຮັບການບັນທຶກຮູບແບບໄຟລ໌ຮູບພາບ: %s"

#: gdk-pixbuf/gdk-pixbuf-io.c:2411
msgid "Insufficient memory to save image to callback"
msgstr "ໜ່ວຍຄວາມຈຳບໍ່ພຽງພໍທີ່ຈະບັນທຶກຮູບພາບໄປຍັງ callback"

#: gdk-pixbuf/gdk-pixbuf-io.c:2424
msgid "Failed to open temporary file"
msgstr "ບໍ່ສາມາດເປີດໄຟລ໌ຊົ່ວຄາວ"

#: gdk-pixbuf/gdk-pixbuf-io.c:2447
msgid "Failed to read from temporary file"
msgstr "ບໍ່ສາມາດອ່ານຈາກໄຟລ໌ຊົ່ວຄາວ"

#: gdk-pixbuf/gdk-pixbuf-io.c:2669
#, c-format
msgid "Failed to open “%s” for writing: %s"
msgstr "ບໍ່ສາມາດເປີດ “%s” ເພື່ອຂຽນ: %s"

#: gdk-pixbuf/gdk-pixbuf-io.c:2695
#, c-format
msgid ""
"Failed to close “%s” while writing image, all data may not have been saved: "
"%s"
msgstr "ບໍ່ສາມາດປິດ “%s” ໃນຂະນະທີ່ກຳລັງຂຽນຮູບພາບ, ຂໍ້ມູນທັງໝົດອາດຈະບໍ່ໄດ້ຖືກບັນທຶກ: %s"

#: gdk-pixbuf/gdk-pixbuf-io.c:2929 gdk-pixbuf/gdk-pixbuf-io.c:2984
msgid "Insufficient memory to save image into a buffer"
msgstr "ໜ່ວຍຄວາມຈຳບໍ່ພຽງພໍທີ່ຈະບັນທຶກຮູບພາບລົງໃນບັບເຟີ"

#: gdk-pixbuf/gdk-pixbuf-io.c:3030
msgid "Error writing to image stream"
msgstr "ຂຽນຂໍ້ມູນລົງສະຕຣີມຮູບພາບຜິດພາດ"

#: gdk-pixbuf/gdk-pixbuf-loader.c:426
#, c-format
msgid ""
"Internal error: Image loader module “%s” failed to complete an operation, "
"but didn’t give a reason for the failure"
msgstr "ຂໍ້ຜິດພາດພາຍໃນ: ໂມດູນໂຫຼດຮູບພາບ “%s” ບໍ່ສາມາດດຳເນີນການໃຫ້ສຳເລັດ, ແຕ່ບໍ່ໄດ້ໃຫ້ເຫດຜົນຂອງຄວາມລົ້ມເຫຼວ"

#: gdk-pixbuf/gdk-pixbuf-loader.c:468
#, c-format
msgid "Incremental loading of image type “%s” is not supported"
msgstr "ບໍ່ຮອງຮັບການໂຫຼດຮູບພາບປະເພດ “%s” ແບບຕໍ່ເນື່ອງ"

#: gdk-pixbuf/gdk-pixbuf-simple-anim.c:164
msgid "Loop"
msgstr "ຫຼິ້ນຊ້ຳ"

#: gdk-pixbuf/gdk-pixbuf-simple-anim.c:165
msgid "Whether the animation should loop when it reaches the end"
msgstr "ກວດສອບວ່າພາບເຄື່ອນໄຫວຄວນຈະຫຼິ້ນຊ້ຳຫຼືບໍ່ເມື່ອຮອດຈຸດສິ້ນສຸດ"

#: gdk-pixbuf/gdk-pixdata.c:178
msgid "Image header corrupt"
msgstr "ສ່ວນຫົວຂອງຮູບພາບເສຍຫາຍ"

#: gdk-pixbuf/gdk-pixdata.c:183
msgid "Image format unknown"
msgstr "ບໍ່ຮູ້ຈັກຮູບແບບຂອງຮູບພາບ"

#: gdk-pixbuf/gdk-pixdata.c:188 gdk-pixbuf/gdk-pixdata.c:491
#: gdk-pixbuf/gdk-pixdata.c:501 gdk-pixbuf/gdk-pixdata.c:597
msgid "Image pixel data corrupt"
msgstr "ຂໍ້ມູນພິກເຊວຂອງຮູບພາບເສຍຫາຍ"

#: gdk-pixbuf/gdk-pixdata.c:513
#, c-format
msgid "failed to allocate image buffer of %u byte"
msgstr "ບໍ່ສາມາດຈັດສັນບັບເຟີຮູບພາບຂະໜາດ %u ໄບຕ໌"

#: gdk-pixbuf/io-ani.c:239
msgid "Unexpected icon chunk in animation"
msgstr "ພົບສ່ວນຂໍ້ມູນໄອຄອນທີ່ບໍ່ຄາດຄິດໃນພາບເຄື່ອນໄຫວ"

#: gdk-pixbuf/io-ani.c:303 gdk-pixbuf/io-ani.c:404 gdk-pixbuf/io-ani.c:430
#: gdk-pixbuf/io-ani.c:449
msgid "Malformed chunk in animation"
msgstr "ສ່ວນຂໍ້ມູນໃນພາບເຄື່ອນໄຫວມີຮູບແບບບໍ່ຖືກຕ້ອງ"

#: gdk-pixbuf/io-ani.c:311 gdk-pixbuf/io-ani.c:354 gdk-pixbuf/io-ani.c:412
#: gdk-pixbuf/io-ani.c:438 gdk-pixbuf/io-ani.c:461 gdk-pixbuf/io-ani.c:488
#: gdk-pixbuf/io-ani.c:575
msgid "Invalid header in animation"
msgstr "ສ່ວນຫົວໃນພາບເຄື່ອນໄຫວບໍ່ຖືກຕ້ອງ"

#: gdk-pixbuf/io-ani.c:364 gdk-pixbuf/io-ani.c:386 gdk-pixbuf/io-ani.c:470
#: gdk-pixbuf/io-ani.c:497 gdk-pixbuf/io-ani.c:548 gdk-pixbuf/io-ani.c:624
msgid "Not enough memory to load animation"
msgstr "ໜ່ວຍຄວາມຈຳບໍ່ພຽງພໍທີ່ຈະໂຫຼດພາບເຄື່ອນໄຫວ"

#: gdk-pixbuf/io-ani.c:646
msgid "ANI image was truncated or incomplete."
msgstr "ຮູບພາບ ANI ຖືກຕັດອອກ ຫຼື ບໍ່ສົມບູນ."

#: gdk-pixbuf/io-ani.c:687
msgctxt "image format"
msgid "Windows animated cursor"
msgstr "ເຄີເຊີພາບເຄື່ອນໄຫວຂອງວິນໂດ"

#: gdk-pixbuf/io-bmp.c:234 gdk-pixbuf/io-bmp.c:275 gdk-pixbuf/io-bmp.c:385
#: gdk-pixbuf/io-bmp.c:412 gdk-pixbuf/io-bmp.c:437 gdk-pixbuf/io-bmp.c:472
#: gdk-pixbuf/io-bmp.c:494 gdk-pixbuf/io-bmp.c:572
msgid "BMP image has bogus header data"
msgstr "ຮູບພາບ BMP ມີຂໍ້ມູນສ່ວນຫົວທີ່ບໍ່ຖືກຕ້ອງ"

#: gdk-pixbuf/io-bmp.c:245 gdk-pixbuf/io-bmp.c:507
msgid "Not enough memory to load bitmap image"
msgstr "ໜ່ວຍຄວາມຈຳບໍ່ພຽງພໍທີ່ຈະໂຫຼດຮູບພາບ bitmap"

#: gdk-pixbuf/io-bmp.c:339
msgid "BMP image has unsupported header size"
msgstr "ຮູບພາບ BMP ມີຂະໜາດສ່ວນຫົວທີ່ບໍ່ຮອງຮັບ"

#: gdk-pixbuf/io-bmp.c:348
msgid "BMP image has unsupported depth"
msgstr "ຮູບພາບ BMP ມີຄວາມເລິກສີທີ່ບໍ່ຮອງຮັບ"

#: gdk-pixbuf/io-bmp.c:367
msgid "BMP image has oversize palette"
msgstr "ຮູບພາບ BMP ມີຊຸດສີຂະໜາດໃຫຍ່ເກີນໄປ"

#: gdk-pixbuf/io-bmp.c:399
msgid "Topdown BMP images cannot be compressed"
msgstr "ຮູບພາບ BMP ແບບເທິງລົງລຸ່ມບໍ່ສາມາດບີບອັດໄດ້"

#: gdk-pixbuf/io-bmp.c:424
msgid "BMP image width too large"
msgstr "ຄວາມກວ້າງຂອງຮູບພາບ BMP ໃຫຍ່ເກີນໄປ"

#: gdk-pixbuf/io-bmp.c:814 gdk-pixbuf/io-png.c:587 gdk-pixbuf/io-pnm.c:722
#: gdk-pixbuf/io-pnm.c:879
msgid "Premature end-of-file encountered"
msgstr "ພົບຈຸດສິ້ນສຸດຂອງໄຟລ໌ກ່ອນກຳນົດ"

#: gdk-pixbuf/io-bmp.c:1340
msgid "Error while decoding colormap"
msgstr "ຜິດພາດຂະນະຖອດລະຫັດຊຸດສີ"

#: gdk-pixbuf/io-bmp.c:1403 gdk-pixbuf/io-bmp.c:1415
msgid "Image is too wide for BMP format."
msgstr "ຮູບພາບກວ້າງເກີນໄປສຳລັບຮູບແບບ BMP."

#: gdk-pixbuf/io-bmp.c:1448
msgid "Couldn’t allocate memory for saving BMP file"
msgstr "ບໍ່ສາມາດຈັດສັນໜ່ວຍຄວາມຈຳສຳລັບບັນທຶກໄຟລ໌ BMP"

#: gdk-pixbuf/io-bmp.c:1489
msgid "Couldn’t write to BMP file"
msgstr "ບໍ່ສາມາດຂຽນລົງໄຟລ໌ BMP"

#: gdk-pixbuf/io-bmp.c:1542 gdk-pixbuf/io-gdip-bmp.c:83
msgctxt "image format"
msgid "BMP"
msgstr "BMP"

#: gdk-pixbuf/io-gdip-emf.c:61
msgctxt "image format"
msgid "EMF"
msgstr "EMF"

#: gdk-pixbuf/io-gdip-gif.c:81 gdk-pixbuf/io-gif.c:1039
msgctxt "image format"
msgid "GIF"
msgstr "GIF"

#: gdk-pixbuf/io-gdip-ico.c:60 gdk-pixbuf/io-ico.c:1418
msgctxt "image format"
msgid "Windows icon"
msgstr "ໄອຄອນວິນໂດ"

#: gdk-pixbuf/io-gdip-jpeg.c:54 gdk-pixbuf/io-jpeg.c:1409
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%s” could not be "
"parsed."
msgstr "ຄຸນນະພາບ JPEG ຕ້ອງເປັນຄ່າລະຫວ່າງ 0 ຫາ 100; ບໍ່ສາມາດວິເຄາະຄ່າ “%s” ໄດ້."

#: gdk-pixbuf/io-gdip-jpeg.c:69 gdk-pixbuf/io-jpeg.c:1425
#, c-format
msgid ""
"JPEG quality must be a value between 0 and 100; value “%d” is not allowed."
